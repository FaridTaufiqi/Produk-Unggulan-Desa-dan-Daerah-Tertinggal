
// ===============================================================
// Assumed Data Model
// ===============================================================
//
// Collection: users
// Document ID: uid
// Fields:
//   - uid: string (required)
//   - role: string (required) - 'admin' or 'desa'
//   - email: string (required)
//
// Collection: submissions
// Document ID: auto-generated
// Fields:
//   - id: string (required) - Registration ID
//   - uid: string (required) - Submitter's UID
//   - timestamp: number (required) - Submission time
//   - provinsi: string (required)
//   - kabupaten: string (required)
//   - kecamatan: string (required)
//   - desa: string (required)
//   - lembagaEkonomi: string (required)
//   - alamatLembaga: string (required)
//   - products: list (optional) - List of products with fields: name, category, deskripsi, mitraUsaha, kapasitasBulanan, kapasitasTahunan, totalPenjualan2025, pangsaPasar, legalitas, fotoUrl
//
// ===============================================================

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() &&
        request.auth.token.email == "faridtaufiqibusiness@gmail.com" && 
        request.auth.token.email_verified == true;
    }

    function isDesa() {
      return isAuthenticated() && 
        request.auth.token.email != "faridtaufiqibusiness@gmail.com";
    }

    function isValidSubmission(data) {
      let requiredFields = [
        'id', 'uid', 'timestamp', 'provinsi', 'kabupaten', 'kecamatan', 'desa', 
        'lembagaEkonomi', 'alamatLembaga', 'namaResponden', 'nikResponden', 
        'noHpResponden', 'jabatanResponden', 'namaLembaga', 'tahunBerdiri',
        'statusBadanHukum', 'noTelpDirektur', 'noTelpSekretaris', 'jumlahKaryawan',
        'npwpLembaga', 'penyertaanModal', 'bagiHasilPADes'
      ];
      
      return data.keys().hasAll(requiredFields) &&
             data.uid == request.auth.uid &&
             data.timestamp is number &&
             data.id is string &&
             data.namaResponden is string && data.namaResponden.size() > 0 && data.namaResponden.size() < 100 &&
             data.nikResponden is string && data.nikResponden.size() == 16 &&
             data.noHpResponden is string && data.noHpResponden.size() > 0 && data.noHpResponden.size() < 20 &&
             data.jabatanResponden is string &&
             data.provinsi is string &&
             data.kabupaten is string &&
             data.kecamatan is string &&
             data.desa is string &&
             data.namaLembaga is string &&
             data.lembagaEkonomi is string &&
             data.statusBadanHukum is string &&
             data.noTelpDirektur is string &&
             data.noTelpSekretaris is string &&
             (data.jumlahKaryawan is string || data.jumlahKaryawan is number) &&
             data.npwpLembaga is string &&
             data.penyertaanModal is string &&
             data.bagiHasilPADes is string &&
             data.tahunBerdiri is string &&
             data.alamatLembaga is string && data.alamatLembaga.size() < 1000 &&
             (!('products' in data) || data.products is list) &&
             (!('kebutuhanDukungan' in data) || data.kebutuhanDukungan is list) &&
             (!('mediaSosial' in data) || data.mediaSosial is string);
    }

    match /users/{userId} {
      allow read: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
      allow create: if isAuthenticated() && request.auth.uid == userId && 
                    ((request.auth.token.email == "faridtaufiqibusiness@gmail.com" && request.resource.data.role == 'admin') ||
                     (request.auth.token.email != "faridtaufiqibusiness@gmail.com" && request.resource.data.role == 'desa'));
      allow update: if isAdmin() || (isAuthenticated() && request.auth.uid == userId && 
                    ((request.auth.token.email == "faridtaufiqibusiness@gmail.com" && request.resource.data.role == 'admin') ||
                     (request.auth.token.email != "faridtaufiqibusiness@gmail.com" && request.resource.data.role == 'desa')));
    }

    match /submissions/{submissionId} {
      // Allow creation for authenticated users (Desa or Admin)
      allow create: if isAuthenticated() && isValidSubmission(request.resource.data);
      
      // Admin sees everything, Desa sees only their own
      allow read: if isAdmin() || (isAuthenticated() && resource.data.uid == request.auth.uid);
      
      // Admin can delete everything, Desa can delete their own
      allow update, delete: if isAdmin() || (isAuthenticated() && resource.data.uid == request.auth.uid);
    }

    match /catalog/{productId} {
      // Public read access for the catalog
      allow read: if true;
      // Only authenticated users can create/update their own products
      allow create: if isAuthenticated() && request.resource.data.uid == request.auth.uid;
      allow update, delete: if isAdmin() || (isAuthenticated() && resource.data.uid == request.auth.uid);
    }

    match /test/connection {
      allow read: if true;
    }
  }
}
