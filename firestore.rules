
// ===============================================================
// Assumed Data Model
// ===============================================================
//
// Collection: users
// Document ID: uid
// Fields:
//   - uid: string (required)
//   - role: string (required) - 'admin' or 'desa'
//   - email: string (required)
//
// Collection: submissions
// Document ID: auto-generated
// Fields:
//   - id: string (required) - Registration ID
//   - uid: string (required) - Submitter's UID
//   - timestamp: number (required) - Submission time
//   - provinsi: string (required)
//   - kabupaten: string (required)
//   - kecamatan: string (required)
//   - desa: string (required)
//   - lembagaEkonomi: string (required)
//   - alamatLembaga: string (required)
//   - products: list (optional) - List of products
//
// ===============================================================

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
          (request.auth.token.email == "faridtaufiqibusiness@gmail.com" && request.auth.token.email_verified == true));
    }

    function isDesa() {
      return isAuthenticated() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'desa';
    }

    function isValidSubmission(data) {
      return data.keys().hasAll(['id', 'uid', 'timestamp', 'provinsi', 'kabupaten', 'kecamatan', 'desa', 'lembagaEkonomi', 'alamatLembaga']) &&
             data.id is string &&
             data.uid == request.auth.uid &&
             data.timestamp is number &&
             data.provinsi is string &&
             data.kabupaten is string &&
             data.kecamatan is string &&
             data.desa is string &&
             data.lembagaEkonomi is string &&
             data.alamatLembaga is string &&
             data.alamatLembaga.size() < 1000;
    }

    match /users/{userId} {
      allow read: if isAuthenticated() && request.auth.uid == userId;
      allow create: if isAuthenticated() && request.auth.uid == userId && 
                    request.resource.data.role in ['admin', 'desa'] &&
                    (request.resource.data.role == 'desa' || isAdmin());
      allow update: if isAdmin();
    }

    match /submissions/{submissionId} {
      // Allow creation for authenticated users (Desa or Admin)
      allow create: if isAuthenticated() && isValidSubmission(request.resource.data);
      
      // Admin sees everything, Desa sees only their own
      allow read: if isAdmin() || (isAuthenticated() && resource.data.uid == request.auth.uid);
      
      // Only admin can delete or update (if needed)
      allow update, delete: if isAdmin();
    }

    match /test/connection {
      allow read: if true;
    }
  }
}
