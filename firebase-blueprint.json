{
  "entities": {
    "User": {
      "title": "User",
      "description": "Profil pengguna (Admin atau Desa)",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "desa"] },
        "villageId": { "type": "string", "description": "Kode desa jika role adalah desa" }
      },
      "required": ["uid", "email", "role"]
    },
    "Submission": {
      "title": "Submission",
      "description": "Data pendaftaran produk unggulan desa",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "ID unik pendaftaran" },
        "uid": { "type": "string", "description": "ID pengguna yang mendaftarkan" },
        "timestamp": { "type": "number", "description": "Waktu pendaftaran" },
        "kodeProvinsi": { "type": "string" },
        "provinsi": { "type": "string" },
        "kodeKabupaten": { "type": "string" },
        "kabupaten": { "type": "string" },
        "kodeKecamatan": { "type": "string" },
        "kecamatan": { "type": "string" },
        "kodeDesa": { "type": "string" },
        "desa": { "type": "string" },
        "lembagaEkonomi": { "type": "string" },
        "lembagaEkonomiLainnya": { "type": "string" },
        "alamatLembaga": { "type": "string" },
        "products": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "name": { "type": "string" },
              "description": { "type": "string" }
            }
          }
        }
      },
      "required": ["id", "timestamp", "provinsi", "kabupaten", "kecamatan", "desa", "lembagaEkonomi", "alamatLembaga"]
    }
  },
  "firestore": {
    "users": {
      "schema": "User",
      "description": "Koleksi profil pengguna"
    },
    "submissions": {
      "schema": "Submission",
      "description": "Koleksi data pendaftaran produk desa"
    }
  }
}
