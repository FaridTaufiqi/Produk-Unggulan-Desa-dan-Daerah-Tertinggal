{
  "entities": {
    "User": {
      "title": "User",
      "description": "Profil pengguna (Admin atau Desa)",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "desa"] },
        "villageId": { "type": "string", "description": "Kode desa jika role adalah desa" }
      },
      "required": ["uid", "email", "role"]
    },
    "Submission": {
      "title": "Submission",
      "description": "Data pendaftaran produk unggulan desa",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "ID unik pendaftaran" },
        "uid": { "type": "string", "description": "ID pengguna yang mendaftarkan" },
        "timestamp": { "type": "number", "description": "Waktu pendaftaran" },
        "namaResponden": { "type": "string" },
        "nikResponden": { "type": "string" },
        "noHpResponden": { "type": "string" },
        "jabatanResponden": { "type": "string" },
        "kodeProvinsi": { "type": "string" },
        "provinsi": { "type": "string" },
        "kodeKabupaten": { "type": "string" },
        "kabupaten": { "type": "string" },
        "kodeKecamatan": { "type": "string" },
        "kecamatan": { "type": "string" },
        "kodeDesa": { "type": "string" },
        "desa": { "type": "string" },
        "namaLembaga": { "type": "string" },
        "lembagaEkonomi": { "type": "string" },
        "statusBadanHukum": { "type": "string" },
        "noTelpDirektur": { "type": "string" },
        "noTelpSekretaris": { "type": "string" },
        "jumlahKaryawan": { "type": "string" },
        "npwpLembaga": { "type": "string" },
        "nibLembaga": { "type": "string" },
        "penyertaanModal": { "type": "string" },
        "bagiHasilPADes": { "type": "string" },
        "mediaSosial": { "type": "string" },
        "tahunBerdiri": { "type": "string" },
        "alamatLembaga": { "type": "string" },
        "products": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "name": { "type": "string" },
              "description": { "type": "string" }
            }
          }
        },
        "kebutuhanDukungan": {
          "type": "array",
          "items": { "type": "string" }
        }
      },
      "required": ["id", "timestamp", "provinsi", "kabupaten", "kecamatan", "desa", "lembagaEkonomi", "alamatLembaga", "statusBadanHukum", "noTelpDirektur", "noTelpSekretaris", "jumlahKaryawan", "npwpLembaga", "penyertaanModal", "bagiHasilPADes"]
    }
  },
  "firestore": {
    "users": {
      "schema": "User",
      "description": "Koleksi profil pengguna"
    },
    "submissions": {
      "schema": "Submission",
      "description": "Koleksi data pendaftaran produk desa"
    }
  }
}
